{
  "name": "LEDManagerLib",
  "version": "1.0.0",
  "description": "A lightweight, non-blocking LED control library for ESP32 boards. Provides clean hardware abstraction and simple APIs for ON/OFF, blink, and status patterns.",
  "keywords": [
    "led",
    "esp32",
    "non-blocking",
    "blink",
    "status",
    "patterns"
  ],
  "authors": [
    {
      "name": "Gary Alose",
      "url": "https://github.com/galose",
      "maintainer": true
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/galose/LEDManagerLib"
  ],
  "license": "MIT",
  "frameworks": "arduino",
  "platforms": [
    "espressif32"
  ],
  "headers": [
    "LEDManagerLib.h"
  ],
  "build": {
    "includeDir": "include",
    "srcDir": "src"
  },
  "examples": [
    "examples/BasicBlink/BasicBlink.ino",
    "examples/RGBCycle/RGBCycle.ino",
    "examples/StatusBlink/StatusBlink.ino",
    "examples/ErrorFlash/ErrorFlash.ino",
    "examples/PulseFade/PulseFade.ino",
    "examples/MultiStatus/MultiStatus.ino"
  ]
}
